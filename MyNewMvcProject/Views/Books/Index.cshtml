@model IEnumerable<MyLibrary.DbModel.Entities.Book>

@{
    ViewData["Title"] = "Books";
}

<h1>Books</h1>

<p>
    <a href="@Url.Action("Create", "Books")" class="btn btn-primary">Create New</a>
</p>

<form method="get" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <label for="title" class="form-label">Title</label>
            <input type="text" class="form-control" id="title" name="title" value="@ViewData["SearchTitle"]" />
        </div>
        <div class="col-md-4">
            <label for="description" class="form-label">Description</label>
            <input type="text" class="form-control" id="description" name="description" value="@ViewData["SearchDescription"]" />
        </div>
        <div class="col-md-4">
            <label for="publisher" class="form-label">Publisher</label>
            <input type="text" class="form-control" id="publisher" name="publisher" value="@ViewData["SearchPublisher"]" />
        </div>
    </div>
    <button type="submit" class="btn btn-primary mt-3">Search</button>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Id</td>
                <td>@book.Title</td>
                <td>
                    <a href="@Url.Action("Details", "Books", new { id = book.Id })" class="btn btn-info btn-sm">Details</a>
                    <a href="@Url.Action("Edit", "Books", new { id = book.Id })" class="btn btn-warning btn-sm">Edit</a>
                    <a href="@Url.Action("Delete", "Books", new { id = book.Id })" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>