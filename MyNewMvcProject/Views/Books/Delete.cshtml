@model MyLibrary.DbModel.Entities.Book

@{
    ViewData["Title"] = "Delete Book";
}

<h1>Delete Book</h1>

<div class="card">
    <div class="card-header">
        <h5>Are you sure you want to delete this book?</h5>
    </div>
    <div class="card-body">
        <p><strong>ID:</strong> @Model.Id</p>
        <p><strong>Title:</strong> @Model.Title</p>
        <p><strong>Description:</strong> @Model.Description</p>
    </div>
</div>

<form method="post" action="@Url.Action("Delete", "Books", new { id = Model.Id })">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Delete</button>
    <a href="@Url.Action("Index", "Books")" class="btn btn-secondary">Cancel</a>
</form>